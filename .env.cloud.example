# =============================================================================
# PLATINUM TIER - CLOUD ENVIRONMENT FILE (SAFE FOR GIT SYNC)
# =============================================================================
# This file contains ONLY non-sensitive configuration.
# It is SAFE to sync this file to Git and share with Cloud VM.
# 
# CRITICAL: This file MUST NOT contain any secrets, tokens, or credentials.
# All secrets must be in .env.cloud (gitignored) on the Cloud VM.
# =============================================================================

# -----------------------------------------------------------------------------
# General Configuration
# -----------------------------------------------------------------------------
AGENT_TYPE=cloud
DRAFT_ONLY_MODE=true
VAULT_PATH=/opt/platinum-vault

# -----------------------------------------------------------------------------
# Odoo Configuration (Read-Only / Draft Access)
# -----------------------------------------------------------------------------
ODOO_URL=http://localhost:8069
ODOO_DATABASE=fahad-graphic-developer
ODOO_USERNAME=cloud_agent@example.com
# Password must be set in .env.cloud on VM, not here
# ODOO_PASSWORD=

# -----------------------------------------------------------------------------
# Gmail Configuration (Read-Only / Draft Access)
# -----------------------------------------------------------------------------
GMAIL_SMTP_SERVER=smtp.gmail.com
GMAIL_SMTP_PORT=587
GMAIL_SENDER_EMAIL=softwarehouse131@gmail.com
# App password must be set in .env.cloud on VM, not here
# GMAIL_APP_PASSWORD=

# -----------------------------------------------------------------------------
# Social Media Configuration (Draft Access Only)
# -----------------------------------------------------------------------------
# Facebook
FACEBOOK_PAGE_ID=110326951910826
# Facebook token must be set in .env.cloud on VM, not here
# FACEBOOK_ACCESS_TOKEN=

# Instagram
INSTAGRAM_ACCOUNT_ID=17841457182813798
# Instagram token must be set in .env.cloud on VM, not here
# INSTAGRAM_ACCESS_TOKEN=

# Twitter/X
TWITTER_USERNAME=software13702
# Twitter API keys must be set in .env.cloud on VM, not here
# TWITTER_API_KEY=
# TWITTER_API_SECRET=
# TWITTER_ACCESS_TOKEN=
# TWITTER_ACCESS_SECRET=

# -----------------------------------------------------------------------------
# MCP Server Configuration
# -----------------------------------------------------------------------------
EMAIL_MCP_PORT=8080
BROWSER_MCP_PORT=8081
ODOO_MCP_PORT=8082
SOCIAL_MCP_PORT=8083
X_MCP_PORT=8084

# MCP Mode (draft only for Cloud)
MCP_MODE=draft

# -----------------------------------------------------------------------------
# Git Sync Configuration
# -----------------------------------------------------------------------------
GIT_SYNC_INTERVAL=5
GIT_REMOTE=origin
GIT_BRANCH=main

# -----------------------------------------------------------------------------
# Health Monitor Configuration
# -----------------------------------------------------------------------------
HEALTH_MONITOR_PORT=5000
HEALTH_CHECK_INTERVAL=60

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_PATH=/opt/platinum-vault/Logs
AUDIT_LOG_ENABLED=true

# -----------------------------------------------------------------------------
# Directory Paths
# -----------------------------------------------------------------------------
NEEDS_ACTION_PATH=/opt/platinum-vault/Needs_Action
IN_PROGRESS_PATH=/opt/platinum-vault/In_Progress/cloud
PENDING_APPROVAL_PATH=/opt/platinum-vault/Pending_Approval
UPDATES_PATH=/opt/platinum-vault/Updates
SIGNALS_PATH=/opt/platinum-vault/Signals
