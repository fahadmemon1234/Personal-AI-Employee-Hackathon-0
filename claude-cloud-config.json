{
  "_comment": "CLOUD AGENT CONFIGURATION - Platinum Tier",
  "_description": "This config is for the 24/7 Cloud Agent running on Oracle Cloud VM. It has DRAFT-ONLY capabilities and ZERO access to secrets.",
  "_agent_type": "cloud",
  "_security_level": "restricted",
  "_capabilities": {
    "email": "triage_and_draft_only",
    "social": "draft_only",
    "odoo": "draft_only",
    "whatsapp": "NO_ACCESS",
    "banking": "NO_ACCESS",
    "payments": "NO_ACCESS"
  },
  "mcpServers": {
    "email-mcp": {
      "command": "python",
      "args": ["mcp_email_server.py", "--mode", "draft"],
      "cwd": "/opt/platinum-vault",
      "env": {},
      "description": "Email management - DRAFT ONLY (no send capability)",
      "capabilities": ["receive-email", "process-email", "draft-reply"],
      "port": 8080,
      "timeout": 60,
      "_restricted": ["send-email"]
    },
    "social-mcp": {
      "command": "python",
      "args": ["mcp_social_server.py", "--mode", "draft"],
      "cwd": "/opt/platinum-vault",
      "env": {},
      "description": "Social media - DRAFT ONLY (no publish capability)",
      "capabilities": ["draft-facebook", "draft-instagram", "get-social-summary"],
      "port": 8083,
      "timeout": 90,
      "_restricted": ["post-facebook", "post-instagram"]
    },
    "x-mcp": {
      "command": "python",
      "args": ["mcp_x_server.py", "--mode", "draft"],
      "cwd": "/opt/platinum-vault",
      "env": {},
      "description": "Twitter/X - DRAFT ONLY (no post capability)",
      "capabilities": ["draft-tweet", "get-recent-posts", "generate-x-summary"],
      "port": 8084,
      "timeout": 60,
      "_restricted": ["post-tweet"]
    },
    "odoo-mcp": {
      "command": "python",
      "args": ["mcp_odoo_server.py", "--mode", "draft"],
      "cwd": "/opt/platinum-vault",
      "env": {},
      "description": "Odoo ERP - DRAFT ONLY (no post capability)",
      "capabilities": ["search-partners", "get-invoices", "draft-invoice", "get-account-balances"],
      "port": 8082,
      "timeout": 60,
      "_restricted": ["post-invoice", "post-journal-entry"]
    },
    "browser-mcp": {
      "command": "python",
      "args": ["mcp_browser_server.py"],
      "cwd": "/opt/platinum-vault",
      "env": {},
      "description": "Browser automation for research",
      "capabilities": ["browse-web", "scrape-content", "automate-browser"],
      "port": 8081,
      "timeout": 120
    }
  },
  "settings": {
    "autoStart": true,
    "logLevel": "info",
    "retryOnFailure": true,
    "maxRetries": 3,
    "agent_type": "cloud",
    "draft_only_mode": true
  },
  "workflow": {
    "enableReasoningLoop": true,
    "approvalRequired": true,
    "autoProcessUnreadEmails": true,
    "crossServerCommunication": true,
    "write_to_pending_approval": true,
    "write_to_updates": true,
    "write_to_dashboard": false
  },
  "directories": {
    "inbox": "/opt/platinum-vault/Inbox",
    "needsAction": "/opt/platinum-vault/Needs_Action",
    "inProgress": "/opt/platinum-vault/In_Progress/cloud",
    "pendingApproval": "/opt/platinum-vault/Pending_Approval",
    "updates": "/opt/platinum-vault/Updates",
    "signals": "/opt/platinum-vault/Signals",
    "approved": "/opt/platinum-vault/Approved",
    "completed": "/opt/platinum-vault/Completed",
    "done": "/opt/platinum-vault/Done"
  },
  "security": {
    "forbidden_paths": [
      "/opt/platinum-vault/.env",
      "/opt/platinum-vault/.env.*",
      "/opt/platinum-vault/whatsapp_data",
      "/opt/platinum-vault/sessions",
      "/opt/platinum-vault/banking",
      "/opt/platinum-vault/creds",
      "/opt/platinum-vault/tokens"
    ],
    "forbidden_files": [
      ".env",
      ".env.local",
      ".env.cloud",
      "credentials.json",
      "token.pickle",
      "*.key",
      "*.pem",
      "*.crt"
    ],
    "no_secret_storage": true,
    "draft_only": true
  },
  "sync": {
    "method": "git",
    "interval_minutes": 5,
    "pull_before_process": true,
    "push_after_process": true,
    "remote": "origin",
    "branch": "main"
  }
}
