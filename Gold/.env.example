# =============================================================================
# Odoo MCP Server Configuration
# =============================================================================
# Copy this file to .env and fill in your actual Odoo credentials
# =============================================================================

# -----------------------------------------------------------------------------
# Odoo Connection Settings
# -----------------------------------------------------------------------------

# Odoo URL (local installation)
ODOO_URL=http://localhost:8069

# Odoo Database Name (create this in Odoo)
ODOO_DB=

# Odoo Username (create user in Odoo Settings → Users)
# Recommended: Create dedicated MCP user with Accounting access
ODOO_USERNAME=


# Odoo Password (set for the MCP user)
ODOO_PASSWORD=


# masterpassword=5c47-ijax-n476

# Optional: Odoo API Key (if using API key instead of password)
# Generate in Odoo: Settings → Users → Your User → Actions → Reset Password
ODOO_API_KEY=

# -----------------------------------------------------------------------------
# MCP Server Settings
# -----------------------------------------------------------------------------

# MCP Server Port (default: 8082)
MCP_ODOO_PORT=8082

# MCP Server Host (0.0.0.0 = all interfaces, localhost = local only)
MCP_ODOO_HOST=0.0.0.0

# -----------------------------------------------------------------------------
# Test Mode Settings
# -----------------------------------------------------------------------------

# Set to 'true' for mock testing (no real Odoo connection)
# Set to 'false' for production use
ODOO_MOCK=false

# -----------------------------------------------------------------------------
# Logging Settings
# -----------------------------------------------------------------------------

# Log level: DEBUG, INFO, WARNING, ERROR
ODOO_LOG_LEVEL=INFO

# Log file path (optional, leave empty for console only)
ODOO_LOG_FILE=

# =============================================================================
# END OF CONFIGURATION
# =============================================================================
